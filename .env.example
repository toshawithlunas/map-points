# Mapbox public access token (starts with "pk."), free tier.
# Get one at https://account.mapbox.com/access-tokens/ and copy it into a
# local file named .env.local (which is gitignored):
#
#   VITE_MAPBOX_TOKEN=pk.your_public_token_here
#
# Recommended: restrict the token by URL in the Mapbox dashboard
# (e.g. http://localhost:5173/* and your production origin).
# Without a token the map area gracefully falls back to a static image.
VITE_MAPBOX_TOKEN=
